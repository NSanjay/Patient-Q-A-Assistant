#MODEL_PROMPT_INJECTION=meta-llama/llama-prompt-guard-2-22m

# JWT
JWT_SECRET=super-secret-jwt-key-change-in-production

# Groq
GROQ_API_KEY=your-groq-api-key-here

# App
PORT=3000
