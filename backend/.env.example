# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=patientqa
DB_USER=admin
DB_PASSWORD=secret

# Models
MODEL_RETRIEVAL=llama-3.1-8b-instant
MODEL_REASONING=openai/gpt-oss-120b
MODEL_PROMPT_REASONING_MAX_TOKENS=4000
MODEL_PROMPT_INJECTION=llama-3.1-8b-instant
